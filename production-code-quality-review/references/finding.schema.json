{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dengyie/awesome-skills/production-code-quality-review/finding.schema.json",
  "title": "Production Code Quality Review Finding",
  "type": "object",
  "required": [
    "severity",
    "title",
    "location",
    "problem",
    "impact",
    "evidence",
    "suggested_fix",
    "confidence",
    "change_classification"
  ],
  "properties": {
    "severity": {
      "enum": ["P0", "P1", "P2", "P3", "Nit"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "location": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "symbol": { "type": "string" }
      },
      "additionalProperties": false
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "impact": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "suggested_fix": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "enum": ["High", "Medium", "Low"]
    },
    "change_classification": {
      "enum": ["new", "worsened", "pre-existing", "unknown"]
    },
    "category": {
      "enum": [
        "correctness",
        "robustness",
        "architecture",
        "security",
        "privacy",
        "performance",
        "observability",
        "tests",
        "maintainability"
      ]
    },
    "fingerprint": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
